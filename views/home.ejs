<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <p class="eyebrow">Security Services Team</p>
        <h1>Reliable Protection for Homes, Businesses, and Facilities</h1>
        <p class="lead">
          METE Security delivers modern protection with trained personnel, smart surveillance,
          and rapid-response coverage tailored to your property.
        </p>
        <div class="tech-badges" aria-label="Security capabilities">
          <span>Live Monitoring</span>
          <span>AI-Assisted Alerts</span>
          <span>Rapid Response</span>
        </div>
        <div class="hero-actions">
          <a href="/services" class="btn btn-gold">Explore Services</a>
          <a href="/contact" class="btn btn-outline">Request Consultation</a>
        </div>
      </div>
      <div class="hero-card">
        <h2>What We Cover</h2>
        <ul>
          <li>Cameras & Monitoring</li>
          <li>Drone Security Patrol</li>
          <li>Unarmed Guard Coverage</li>
          <li>Armed Guard Operations</li>
          <li>And more custom solutions</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="tech-strip" aria-label="Operational highlights">
    <div class="container tech-strip-grid">
      <article>
        <h3>24/7 Coverage Design</h3>
        <p>Coverage plans designed around your operating hours and property risk zones.</p>
      </article>
      <article>
        <h3>Layered Protection Model</h3>
        <p>Physical guards, camera visibility, and drone support in one security strategy.</p>
      </article>
      <article>
        <h3>Incident-Ready Operations</h3>
        <p>Clear response protocols for better reporting, escalation, and accountability.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container quick-grid">
      <article class="feature-card">
        <h3>Professional Team</h3>
        <p>Vetted and trained personnel focused on prevention, response, and safety compliance.</p>
      </article>
      <article class="feature-card">
        <h3>Modern Technology</h3>
        <p>Integrated cameras and aerial support to provide stronger situational awareness.</p>
      </article>
      <article class="feature-card">
        <h3>Tailored Security Plans</h3>
        <p>Each deployment is designed around your location, risks, and operational goals.</p>
      </article>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
